{
  "permissions": {
    "allow": [
      "Bash(python3 scripts/frontmatter.py *)",
      "Bash(python3 scripts/state.py *)",
      "Bash(python3 scripts/repo_readiness.py *)",
      "Bash(python3 scripts/validate_target.py *)",
      "Bash(python3 scripts/clone_target.py *)",
      "Bash(python3 scripts/score_reviews.py *)",
      "Bash(python3 scripts/review_cycle.py *)",
      "Bash(python3 scripts/run_index.py *)",
      "Bash(python3 scripts/fetch_epic.py *)",
      "Bash(python3 scripts/fetch_jira_epics.py *)",
      "Bash(python3 scripts/run_pipeline.py *)",
      "Bash(*/scripts/task-brief *)",
      "Bash(*/scripts/review-package *)",
      "Bash(*/scripts/sdd-workspace)"
    ],
    "additionalDirectories": [".target-repo"]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/review_cycle.py dispatch-context"
          }
        ]
      }
    ]
  }
}
