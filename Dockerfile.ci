FROM registry.access.redhat.com/ubi9/ubi:latest

# Base tools (mirrors strat-pipeline's setup-claude-ci.sh, baked in for speed)
RUN dnf install -y --nodocs --allowerasing \
        git-core \
        shadow-utils \
        util-linux \
        python3.11 \
        python3.11-pip \
        python3.11-devel \
        gcc \
        make \
        diffutils \
        patch \
        findutils \
        which \
        tar \
        gzip \
        unzip \
        curl \
        wget \
    && dnf clean all \
    && alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 \
    && alternatives --install /usr/bin/pip3 pip3 /usr/bin/pip3.11 1

# Go 1.24 (required by mlflow-go)
ARG TARGETARCH
RUN curl -fsSL "https://go.dev/dl/go1.24.4.linux-${TARGETARCH}.tar.gz" | tar -C /usr/local -xzf -
ENV PATH="/usr/local/go/bin:${PATH}"
ENV GOPATH="/home/claude-ci/go"

# Node.js 22 (required by odh-dashboard: engines.node >= 22)
RUN curl -fsSL https://rpm.nodesource.com/setup_22.x | bash - \
    && dnf install -y --nodocs nodejs \
    && dnf clean all \
    && npm install -g yarn

# Python packages needed by epic-code-gen
RUN pip3 install --no-cache-dir pyyaml pytest

# Playwright for UX prototype parsing (parse_prototype.js)
# Browsers go to /opt/playwright so both root and claude-ci can access them
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright
RUN npm install -g playwright \
    && npx playwright install chromium \
    && dnf install -y --nodocs \
        alsa-lib atk at-spi2-atk cups-libs libdrm libXcomposite libXdamage \
        libXrandr mesa-libgbm pango \
    && dnf clean all \
    && chmod -R 755 /opt/playwright

# Non-root user (required by Claude Code)
RUN useradd -m claude-ci \
    && mkdir -p /home/claude-ci/.local/bin \
    && chown -R claude-ci:claude-ci /home/claude-ci

# Claude Code CLI
RUN runuser -l claude-ci -c 'curl -fsSL https://claude.ai/install.sh | bash'
ENV PATH="/home/claude-ci/.claude/local/bin:/home/claude-ci/.local/bin:${PATH}"

# Superpowers plugin (SDD skill used by epic-codegen)
RUN runuser -l claude-ci -c 'claude plugin marketplace add obra/superpowers' \
    && runuser -l claude-ci -c 'claude plugin install superpowers@superpowers-dev'

# Trust /tmp/claude-workdir so Claude Code loads .claude/settings.json
RUN mkdir -p /home/claude-ci && \
    echo '{"projects":{"/tmp/claude-workdir":{"hasTrustDialogAccepted":true}}}' \
    > /home/claude-ci/.claude.json && \
    chown claude-ci:claude-ci /home/claude-ci/.claude.json

# Verify installations
RUN python3 --version \
    && go version \
    && node --version \
    && npm --version \
    && runuser -u claude-ci -- claude --version

USER claude-ci
WORKDIR /home/claude-ci
